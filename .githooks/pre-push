#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

if git rev-parse --abbrev-ref --symbolic-full-name @{u} >/dev/null 2>&1; then
  RANGE="@{u}...HEAD"
  CHANGED_FILES=$(git diff --name-only --diff-filter=ACMR "$RANGE")
else
  if git rev-parse --verify HEAD~1 >/dev/null 2>&1; then
    CHANGED_FILES=$(git diff --name-only --diff-filter=ACMR HEAD~1...HEAD)
  else
    CHANGED_FILES=$(git diff --name-only --diff-filter=ACMR --root HEAD)
  fi
fi

if [ -z "$CHANGED_FILES" ]; then
  exit 0
fi

run_frontend=false
run_backend=false

while IFS= read -r file; do
  [[ -z "$file" ]] && continue

  if [[ "$file" == src/supabase/functions/* || "$file" == supabase/functions/* ]]; then
    run_backend=true
    continue
  fi

  case "$file" in
    src/*|index.html|vite.config.ts|package.json|package-lock.json|tsconfig.json|eslint.config.*|.prettierrc.*|prettier.config.*|vitest.config.*)
      run_frontend=true
      ;;
  esac
done <<< "$CHANGED_FILES"

if [ "$run_frontend" = false ] && [ "$run_backend" = false ]; then
  exit 0
fi

# Enforce single commit when pushing: AI review (commit mode) only reviews HEAD~1..HEAD; older commits would stay unreviewed.
# Only when upstream exists (normal push); first push (no upstream yet) is not enforced.
if git rev-parse --abbrev-ref --symbolic-full-name @{u} >/dev/null 2>&1; then
  AHEAD=$(git rev-list --count @{u}..HEAD) || { echo "Pre-push: Konnte Commit-Anzahl nicht ermitteln (git rev-list fehlgeschlagen)." >&2; exit 1; }
  if [ -z "$AHEAD" ] || ! [ "$AHEAD" -ge 0 ] 2>/dev/null; then
    echo "Pre-push: Ungültige Commit-Anzahl ($AHEAD)." >&2
    exit 1
  fi
  if [ "$AHEAD" -gt 1 ]; then
    echo "Pre-push: Mehrere lokale Commits ($AHEAD) gegenüber Upstream. AI-Review prüft nur den letzten. Bitte squashen (z. B. git rebase -i @{u}) oder einzeln pushen." >&2
    exit 1
  fi
fi

# Pre-push: fast checks + AI review in commit mode (only latest commit HEAD~1..HEAD); stable, no shifting diff.
CHECK_ARGS=()
[ "$run_frontend" = true ] && CHECK_ARGS+=(--frontend)
[ "$run_backend" = true ] && CHECK_ARGS+=(--backend)
export CHECK_MODE=commit
bash scripts/run-checks.sh "${CHECK_ARGS[@]}"

# Update README (e.g. "Last updated" line) so it stays in sync on push
if [ -f scripts/update-readme-on-push.sh ]; then
  bash scripts/update-readme-on-push.sh
  if ! git diff --quiet README.md 2>/dev/null; then
    git add README.md
    git commit -m "docs: update README (auto on push)"
  fi
fi
